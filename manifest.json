{
  "manifest_version": 3,
  "name": "RMB → USD Price Converter",
  "version": "1.0.0",
  "description": "Shows the USD equivalent next to RMB prices (¥ / ￥ / CNY / RMB / 元) on any page, using an exchange rate you set yourself.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RMB → USD converter settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
